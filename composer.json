{
    "name": "vixen/laravel-breadcrumbs",
    "description": "Yet another breadcrumbs package for Laravel: simple and easy to use.",
    "type": "library",
    "keywords": [
        "laravel",
        "breadcrumbs",
        "crumbs",
        "navigation"
    ],
    "readme": "./README.md",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^v11.0.0",
        "pestphp/pest": "^v4.4.3",
        "pestphp/pest-plugin-laravel": "^v4.1.0"
    },
    "replace": {
        "atorscho/laravel-breadcrumbs": "2.4.*",
        "atstudio-tech/breadcrumbs": "v3.0.3"
    },
    "autoload": {
        "psr-4": {
            "Vixen\\Breadcrumbs\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Vixen\\Breadcrumbs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vixen\\Breadcrumbs\\BreadcrumbsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
